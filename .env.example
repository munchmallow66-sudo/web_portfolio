# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  ENVIRONMENT VARIABLES — Portfolio Web App
#  Copy this file to .env and fill in real values
#  NEVER commit .env to version control
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# ─── Database (Neon PostgreSQL) ──────────────────────────────
# Pooled connection (for application use in serverless)
DATABASE_URL="postgresql://user:password@host-pooler.region.aws.neon.tech/dbname?sslmode=require&pgbouncer=true"
# Direct connection (for Prisma migrations — non-pooled)
DIRECT_URL="postgresql://user:password@host.region.aws.neon.tech/dbname?sslmode=require"

# ─── Authentication ─────────────────────────────────────────
# Generate a strong secret:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=""

# ─── Cloudinary (Image CDN & Uploads) ──────────────────────
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# ─── Email (SMTP) ───────────────────────────────────────────
# For Gmail: SMTP_HOST=smtp.gmail.com, SMTP_PORT=587
# Enable "Less secure app access" or use App Password
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"

# ─── Public (Exposed to browser) ────────────────────────────
# Your production domain (no trailing slash)
NEXT_PUBLIC_SITE_URL="https://yourportfolio.com"

# ─── Runtime ────────────────────────────────────────────────
# Set automatically by Vercel; override locally if needed
NODE_ENV="development"

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  VERCEL DEPLOYMENT CHECKLIST
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  1. Add ALL variables above to Vercel → Settings → Environment Variables
#  2. Set Build Command to: npm run vercel-build
#  3. Ensure Prisma migrations are in prisma/migrations/ (committed to git)
#  4. vercel-build runs "prisma migrate deploy" before "next build"
#  5. HTTPS is automatic on Vercel (*.vercel.app and custom domains)
